{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [{ "key": "Content-Type", "value": "application/json" }]
    },
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [{ "key": "Content-Type", "value": "application/json" }]
    }
  ],
  "rewrites": [
    { "source": "/user/:id",       "destination": "/api/user?id=:id" },
    { "source": "/collection/:id", "destination": "/api/collection?id=:id" },
    { "source": "/sotd/:id",       "destination": "/api/sotd?id=:id" },
    { "source": "/fragrance/:id",  "destination": "/api/fragrance?id=:id" },
    { "source": "/review/:id",     "destination": "/api/review?id=:id" }
  ]
}
