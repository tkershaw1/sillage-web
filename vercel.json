{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [{ "key": "Content-Type", "value": "application/json" }]
    },
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [{ "key": "Content-Type", "value": "application/json" }]
    }
  ],
  "rewrites": [
    { "source": "/sotd/:id",       "destination": "/" },
    { "source": "/collection/:id", "destination": "/" },
    { "source": "/fragrance/:id",  "destination": "/" },
    { "source": "/user/:id",       "destination": "/" },
    { "source": "/review/:id",     "destination": "/" }
  ]
}
